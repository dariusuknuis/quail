    "version": "0.2.0",
    "configurations": [
        {
            "name": "Launch Package",
            "type": "go",
            "request": "launch",
            "mode": "auto",
            "program": "${fileDirname}"
        },
	    {
            "name": "Debug quail",
            "type": "go",
            "request": "launch",
            "mode": "auto",
            "program": "${workspaceFolder}",
            "cwd": "${workspaceFolder}",
            "env": {
                "EQ_PATH": "C:\\MyEQServer"
            },
            "args": [
                "convert",
                "${workspaceFolder}/bin/avi_chr.s3d",
                "${workspaceFolder}/bin/avi_chr.quail"
            ],
            "buildFlags": "-gcflags=all='-N -l'"
        }
    ]
}